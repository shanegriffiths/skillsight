{
  "name": "skillsight",
  "version": "0.1.0",
  "description": "Read-only cross-runtime inventory of AI-agent skills, plugins, and MCP servers — grouped by folder, with provenance and which runtimes use each.",
  "type": "module",
  "license": "MIT",
  "author": "Shane Griffiths",
  "homepage": "https://github.com/studiobrio/skillsight#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/studiobrio/skillsight.git"
  },
  "bugs": {
    "url": "https://github.com/studiobrio/skillsight/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "skills",
    "mcp",
    "plugins",
    "claude-code",
    "codex",
    "inventory",
    "cli"
  ],
  "bin": {
    "skillsight": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "ink": "^7.1.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "smol-toml": "^1.7.0",
    "terminal-link": "^5.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
